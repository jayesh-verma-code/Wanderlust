<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
    <%- include("../layouts/metadata.ejs") %>
</head>
<body>
    <%- include("../layouts/navbar.ejs") %>

    <div class="container">
        <div class="row justify-content-center" style="margin-top: 40px;">
            <% for(let list of allListings) { %>
            <a href="/listings/<%= list._id %>" class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card h-100">
                    <img src="<%= list.image %>" class="card-img-top" alt="<%= list.title %>" style="width: 100%; height: 180px; object-fit: cover;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <h3 style="font-size: 1.1rem;"><%= list.title %></h3>
                        <p class="card-text">
                            &#8377;<%= list.price.toLocaleString("en-IN") %> / night
                        </p>
                    </div>
                </div>
            </a>
            <% } %>
        </div>
    </div>
    

    <%- include("../layouts/footer.ejs") %>
    <%- include("../layouts/script.ejs") %>
</body>
</html>
