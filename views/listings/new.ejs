<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create New Listing</title>
    <%- include("../layouts/metadata.ejs") %>
  </head>
  <body>
    <%- include("../layouts/navbar.ejs") %>
    <main class="container mt-4">
      <h3 class="mb-4">Create a new listing</h3>

      <form method="POST" action="/listings" novalidate class="needs-validation">

        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
        <input id="title" name="listing[title]" placeholder="Enter title" type="text" class="form-control" required/>
        <div class="invalid-feedback">Please enter a title.</div>
        </div>
        
        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
        <textarea
          id="description"
          name="listing[description]"
          class="form-control"
          placeholder="Enter description"
          type="text"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter a description.</div>
        </div>

        <div class="row mb-3">

          <div class="col col-lg-6 col-sm-12">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" placeholder="Enter price" type="number" class="form-control" min="0" required/>
            <div class="invalid-feedback">Enter a valid price.</div>
          </div>
          

          <div class="col-12 col-lg-6 col-sm-12">
            <label for="image" class="form-label">Image UR <span style="color: rgb(131, 131, 131);">(Optional)</span></label>
            <input id="image" name="listing[image]" placeholder="Enter image url" type="text" class="form-control"/>
          </div>
      
        </div>

        <div class="row mb-3">

          <div class="col col-lg-8 col-sm-12">
           <label for="location" class="form-label">Address</label>
           <input id="location" name="listing[location]" placeholder="Enter location" type="text"  class="form-control" required/>
           <div class="invalid-feedback">Proper address needed.</div>
          </div>

          <div class="col-12 col-lg-4 col-sm-12">
            <label for="country" class="form-label">Country</label>
            <input id="country" name="listing[country]" placeholder="Enter country" type="text"  class="form-control" required/>
            <div class="invalid-feedback">Please enter country.</div>
          </div>
      
        </div>
         
        <button type="submit" class="btn btn-dark mt-3">Create</button>
      </form>
    </main>
    <%- include("../layouts/footer.ejs") %> <%- include("../layouts/script.ejs")
    %>
  </body>
</html>
